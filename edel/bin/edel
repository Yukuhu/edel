#!/usr/bin/env bash
# Starter fuer das edel-Werkzeug.
# Bevorzugt das native GraalVM-Binaerprogramm; faellt sonst auf das Jar zurueck.
set -euo pipefail

WURZEL="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
NATIV="$WURZEL/build/edel"
JAR="$WURZEL/build/libs/edel.jar"

if [[ -x "$NATIV" ]]; then
    exec "$NATIV" "$@"
fi

if [[ -f "$JAR" ]]; then
    exec java -jar "$JAR" "$@"
fi

echo "Weder das native edel-Programm noch edel.jar wurde gefunden." >&2
echo "Bitte zuerst './gradlew fatJar' (Jar) oder './gradlew nativeCompile' (nativ) ausfuehren." >&2
exit 1
